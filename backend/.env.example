# RayCarwash - Backend Configuration
# Copy this file to .env and fill in the values

# ──────────────────────────────────────────────
#  Application
# ──────────────────────────────────────────────
DEBUG=true
PROJECT_NAME=RayCarwash API
API_VERSION=v1
APP_BASE_URL=http://localhost:8000

# ──────────────────────────────────────────────
#  Database (PostgreSQL with asyncpg)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/raycarwash
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ──────────────────────────────────────────────
#  Security / JWT
# ──────────────────────────────────────────────
# JWT_SECRET_KEY: Used ONLY for JWT signing (HS256).
#                 IMPORTANT: Do NOT use for encryption - see ENCRYPTION_KEY below.
#                 Generate: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key-here-generate-with-openssl-rand-hex-32

# ENCRYPTION_KEY: Used ONLY for PII encryption (full_name, phone_number).
#                IMPORTANT: Should be ROTATED INDEPENDENTLY from JWT_SECRET_KEY.
#                If you rotate JWT_SECRET_KEY, PII remains secure.
#                Generate: openssl rand -base64 32
ENCRYPTION_KEY=your-encryption-key-here-generate-with-openssl-rand-base64-32

# PHONE_LOOKUP_KEY: HMAC key for phone number hashing (for efficient lookup).
#                 Prevents rainbow table attacks on phone hashes.
#                 Generate: openssl rand -hex 32
PHONE_LOOKUP_KEY=your-phone-lookup-key-here-generate-with-openssl-rand-hex-32

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────────
#  Stripe (use test keys for development)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_CURRENCY=usd

# ──────────────────────────────────────────────
#  Rate Limiting
# ──────────────────────────────────────────────
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=120

# ──────────────────────────────────────────────
#  Business Logic
# ──────────────────────────────────────────────
TRAVEL_BUFFER_MINUTES=30
CANCELLATION_FULL_REFUND_HOURS=24
CANCELLATION_PARTIAL_REFUND_HOURS=2
CANCELLATION_PARTIAL_REFUND_PERCENT=50

# ──────────────────────────────────────────────
#  Email (SMTP)
# ──────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@raycarwash.com
SMTP_FROM_NAME=RayCarwash

# ──────────────────────────────────────────────
#  OAuth (optional for development)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
APPLE_BUNDLE_ID=com.raycarwash.app

# ──────────────────────────────────────────────
#  CORS
# ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081
