# RayCarwash - Frontend Configuration
# Copy this file to .env and fill in the values

# API Backend URL (use your computer's IP for mobile testing)
EXPO_PUBLIC_API_URL=http://192.168.0.1:8000

# OAuth Providers (optional - get from Google/Apple developer consoles)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_APPLE_BUNDLE_ID=com.raycarwash.app
